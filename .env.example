# Salin file ini jadi `.env`, lalu isi dengan kredensial project Supabase kamu.
# Ambil dari: Supabase Dashboard -> tombol "Connect"
#   (atau Project Settings -> Data API untuk URL, dan API Keys untuk key).
# Catatan: publishable key AMAN dipakai di app client karena dijaga RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
